rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the authenticated user's email is registered in the 'admins' collection
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Admins collection: Only authenticated admins can read and write
    match /admins/{email} {
      allow read, write: if request.auth != null && (request.auth.token.email == email || isAdmin());
    }

    // App Settings, AdMob Settings, AI Settings: Anyone can read (so mobile clients can sync), but only admins can write
    match /app_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admob_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ai_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /versions/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users collection: Admins can read/write all. Users can read/write their own document.
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && (request.auth.uid == userId || request.auth.token.email.replace("\\.", "_") == userId));
    }

    // Notifications: Anyone can read, but only admins can write
    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics: Admins can read/write. Authenticated users can write/update.
    match /analytics/{docId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    // Logs: Only admins can read, but admins and authenticated clients can write diagnostic logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.auth != null;
    }
  }
}
